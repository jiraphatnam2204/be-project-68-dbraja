      "item": [
        {
          "name": "Get All Companies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Parse the response body as JSON",
                  "const responseData = pm.response.json();",
                  "",
                  "// 2. Guard check before accessing the data array",
                  "if (responseData && responseData.data && responseData.data.length > 0) {",
                  "    // 3. Extract the ID from the first company in the list",
                  "    const company_id = responseData.data[0].id;",
                  "",
                  "    // 4. Set the variable so the next request can use it",
                  "    pm.environment.set(\"company_id\", company_id);",
                  "} else {",
                  "    console.error(\"No company data found in response\");",
                  "}",
                  "",
                  "// Your existing code",
                  "pm.test(\"Companies list is an array\", () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.execution.setNextRequest(\"Create Registration (Invalid)\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
